# ---------- Server ----------
PORT=4000
NODE_ENV=development

# ---------- MySQL ----------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=device_tracker

# ---------- Admin login ----------
# Change these before deploying. Password will be bcrypt-hashed on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# ---------- Auth ----------
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=12h

# ---------- CORS ----------
FRONTEND_ORIGIN=http://localhost:5173

# ---------- Email (SMTP) ----------
# Your organization's mail gateway
SMTP_HOST=mail.yourcompany.com
SMTP_PORT=25
SMTP_FROM=devicehub@yourcompany.com
FRONTEND_URL=http://localhost:5173
